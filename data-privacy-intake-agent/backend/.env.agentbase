# =============================================================================
# AgentBase Deployment Environment Configuration
# =============================================================================
# File này chứa environment variables sẽ được inject vào container khi deploy
# lên GreenNode AgentBase.
#
# LƯU Ý QUAN TRỌNG:
# - KHÔNG đặt các biến sau (AgentBase tự động inject):
#   - GREENNODE_CLIENT_ID
#   - GREENNODE_CLIENT_SECRET  
#   - GREENNODE_AGENT_IDENTITY
#   - GREENNODE_ENDPOINT_URL
# =============================================================================

# =============================================================================
# LLM API Configuration
# =============================================================================
# RECOMMENDED: Sử dụng GreenNode AI Platform (MaaS) - tích hợp sẵn với AgentBase
# Base URL: https://maas-llm-aiplatform-hcm.api.vngcloud.vn/v1
# Lấy API key tại: https://aiplatform.console.vngcloud.vn/api-key

LLM_API_KEY=your-greennode-aip-api-key
LLM_MODEL=gpt-4o-mini
LLM_BASE_URL=https://maas-llm-aiplatform-hcm.api.vngcloud.vn/v1

# Alternative: OpenAI direct
# LLM_API_KEY=sk-your-openai-key
# LLM_MODEL=gpt-4o-mini
# LLM_BASE_URL=https://api.openai.com/v1

# =============================================================================
# Database Configuration (REQUIRED - External PostgreSQL)
# =============================================================================
# AgentBase không cung cấp database - bạn cần external PostgreSQL
# 
# Options:
# - Supabase: https://supabase.com (Free tier)
# - Neon: https://neon.tech (Free tier)
# - VNG Cloud RDS
# - Any PostgreSQL provider

DATABASE_URL=postgresql://user:password@host:5432/database_name

# =============================================================================
# JWT Authentication
# =============================================================================
# Secret key cho JWT token - đổi thành giá trị ngẫu nhiên an toàn
# Generate: python -c "import secrets; print(secrets.token_hex(32))"

JWT_SECRET_KEY=your-secure-jwt-secret-key-change-this
ACCESS_TOKEN_EXPIRE_MINUTES=1440
