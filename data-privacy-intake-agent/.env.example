# Data Privacy Intake Agent - Environment Configuration v2.0
# Copy this file to .env and fill in your values

# =============================================================================
# LLM API Configuration
# =============================================================================

# OpenAI API Key hoặc API key tương thích
# Lấy từ: https://platform.openai.com/api-keys
# Nếu để trống, hệ thống sẽ dùng mock response để demo
LLM_API_KEY=your-api-key-here

# Model name để sử dụng (có thể thay đổi trong UI Settings)
# Options: gpt-4o-mini, gpt-4o, gpt-4-turbo, gemini-1.5-pro, qwen-max
LLM_MODEL=gpt-4o-mini

# Base URL của LLM API
# OpenAI: https://api.openai.com/v1
# Azure: https://your-resource.openai.azure.com/
# VNG Cloud: https://maas-llm-aiplatform-hcm.api.vngcloud.vn/v1
LLM_BASE_URL=https://api.openai.com/v1

# =============================================================================
# Database Configuration (PostgreSQL)
# =============================================================================

# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database
# Docker default (don't change if using docker-compose):
DATABASE_URL=postgresql://privacy_agent:privacy_agent_pass@postgres:5432/privacy_agent_db

# For local development (if running backend locally):
# DATABASE_URL=postgresql://privacy_agent:privacy_agent_pass@localhost:5432/privacy_agent_db

# =============================================================================
# PostgreSQL Credentials (used in docker-compose.yml)
# =============================================================================

POSTGRES_USER=privacy_agent
POSTGRES_PASSWORD=privacy_agent_pass
POSTGRES_DB=privacy_agent_db

# Change password for production:
# POSTGRES_PASSWORD=your_secure_password_here

# =============================================================================
# Application Settings
# =============================================================================

# Backend URL for frontend (in docker network)
BACKEND_URL=http://backend:8000

# For local development:
# BACKEND_URL=http://localhost:8000

# =============================================================================
# Usage Instructions
# =============================================================================
#
# 1. Copy this file:
#    cp .env.example .env
#
# 2. Edit .env and add your API key:
#    LLM_API_KEY=sk-...your-key-here
#
# 3. (Optional) Change PostgreSQL password for production
#
# 4. Start services:
#    docker-compose up --build -d
#
# 5. Access:
#    - Frontend: http://localhost:8501
#    - Backend: http://localhost:8000
#    - Postgres: localhost:5432
#
# 6. Connect to database:
#    psql -h localhost -p 5432 -U privacy_agent -d privacy_agent_db
#
# =============================================================================
# Security Notes
# =============================================================================
#
# ⚠️ NEVER commit .env file to git
# ⚠️ Change default passwords in production
# ⚠️ Use strong passwords for PostgreSQL
# ⚠️ Restrict PostgreSQL port access in production
# ⚠️ Enable SSL for database connections in production
#
# =============================================================================
