# Data Privacy Intake Agent - Environment Configuration
# Vui lòng điền các thông tin sau:

# =============================================================================
# LLM API Configuration
# =============================================================================

# OpenAI API Key hoặc API key tương thích
# Lấy từ: https://platform.openai.com/api-keys
# Nếu để trống, hệ thống sẽ dùng mock response để demo
LLM_API_KEY=vn-h_Z05Hb1_l11RXj_D-kM_luG7UfSWD118cf2de16de4a8fac5d38bb6bcab23ccurWUX8pkCl7c8iM-6k_Jrt3ouS4zta

# Model name để sử dụng
# Gợi ý: gpt-4o-mini (rẻ, nhanh), gpt-4 (chất lượng cao hơn)
LLM_MODEL=qwen/qwen3-5-27b

# Base URL của LLM API
# Mặc định: https://api.openai.com/v1
# Nếu dùng provider khác (Azure, custom), thay đổi URL này
LLM_BASE_URL=https://maas-llm-aiplatform-hcm.api.vngcloud.vn/v1

# =============================================================================
# Hướng dẫn sử dụng:
# =============================================================================
#
# 1. Nếu BẠN CÓ OpenAI API key:
#    - Nhập API key vào LLM_API_KEY
#    - Giữ nguyên LLM_MODEL và LLM_BASE_URL
#    - Save file này
#    - Chạy: docker-compose up -d
#
# 2. Nếu BẠN KHÔNG CÓ API key (demo nhanh):
#    - Để trống LLM_API_KEY
#    - Hệ thống sẽ dùng mock response (vẫn demo được đầy đủ tính năng)
#    - Chạy: docker-compose up -d
#
# 3. Nếu dùng Azure OpenAI hoặc provider khác:
#    - Thay đổi LLM_BASE_URL
#    - Nhập API key tương ứng
#    - Có thể cần thay đổi LLM_MODEL
#
# =============================================================================
# Ví dụ cấu hình:
# =============================================================================
#
# Ví dụ 1: OpenAI GPT-4o-mini (recommended cho demo)
# LLM_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxx
# LLM_MODEL=gpt-4o-mini
# LLM_BASE_URL=https://api.openai.com/v1
#
# Ví dụ 2: OpenAI GPT-4 (chất lượng cao hơn nhưng chậm và đắt hơn)
# LLM_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxx
# LLM_MODEL=gpt-4
# LLM_BASE_URL=https://api.openai.com/v1
#
# Ví dụ 3: Demo không cần API key
# LLM_API_KEY=
# LLM_MODEL=gpt-4o-mini
# LLM_BASE_URL=https://api.openai.com/v1
#
# =============================================================================

# Sau khi điền xong, lưu file này và chạy:
# docker-compose up -d

# Kiểm tra backend: http://localhost:8000/health
# Mở web UI: http://localhost:8501
